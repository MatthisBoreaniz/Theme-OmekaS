<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Reset button ───────────────────────────────────────────────────── */
    document.getElementById('reset-search').addEventListener('click', function () {
        var form = document.getElementById('advanced-search');
        form.querySelectorAll('input[type="text"], input[type="search"]').forEach(function (i) { i.value = ''; });
        form.querySelectorAll('select').forEach(function (s) { s.selectedIndex = 0; });
        form.querySelectorAll('.value:not(:first-child)').forEach(function (r) { r.remove(); });
        closeAllDropdowns();
    });

    /* ── Custom dropdown logic ──────────────────────────────────────────── */
    function closeAllDropdowns() {
        document.querySelectorAll('.sf-dropdown.open').forEach(function (d) {
            d.classList.remove('open');
        });
        document.querySelectorAll('.sf-arrow.active').forEach(function (b) {
            b.classList.remove('active');
        });
    }

    /* Filter items in a dropdown */
    function filterDropdown(dropdown, term) {
        var t = term.toLowerCase();
        dropdown.querySelectorAll('li').forEach(function (li) {
            li.style.display = (!t || li.textContent.toLowerCase().includes(t)) ? '' : 'none';
        });
    }

    /* Open / close on arrow click */
    document.querySelectorAll('.sf-arrow').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var wrap    = btn.closest('.sf-input-wrap');
            var input   = wrap.querySelector('input[type="text"]');
            var listId  = input.dataset.sflist;
            var dropdown = document.getElementById(listId);
            if (!dropdown) return;

            var isOpen = dropdown.classList.contains('open');
            closeAllDropdowns();
            if (!isOpen) {
                filterDropdown(dropdown, input.value);
                dropdown.classList.add('open');
                btn.classList.add('active');
            }
        });
    });

    /* Filter on typing */
    document.querySelectorAll('input[data-sflist]').forEach(function (input) {
        input.addEventListener('input', function () {
            var listId   = input.dataset.sflist;
            var dropdown = document.getElementById(listId);
            if (!dropdown) return;
            filterDropdown(dropdown, input.value);
            if (!dropdown.classList.contains('open')) {
                dropdown.classList.add('open');
                var btn = input.closest('.sf-input-wrap').querySelector('.sf-arrow');
                if (btn) btn.classList.add('active');
            }
        });

        /* Select item from dropdown */
        var listId   = input.dataset.sflist;
        var dropdown = document.getElementById(listId);
        if (dropdown) {
            dropdown.querySelectorAll('li').forEach(function (li) {
                li.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    input.value = li.textContent;
                    closeAllDropdowns();
                });
            });
        }
    });

    /* Close on outside click */
    document.addEventListener('click', closeAllDropdowns);

    /* Close on Escape */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAllDropdowns();
    });
});
</script>

