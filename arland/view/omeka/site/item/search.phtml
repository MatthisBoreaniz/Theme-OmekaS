$translate = $this->plugin('translate');
$this->htmlElement('body')->appendAttribute('class', 'items search');
?>

<div class="custom-search-container">

    <div class="search-header">
        <h2>Recherche avancée</h2>
    </div>

    <form id="advanced-search" method="get"
        action="<?php echo $this->escapeHtml($this->url(null, ['action' => 'browse'], true)); ?>">

        <?php
        $this->headLink()->prependStylesheet($this->assetUrl('css/advanced-search.css', 'Omeka'));
        $this->headScript()->appendFile($this->assetUrl('js/advanced-search.js', 'Omeka'));
        $query = $this->params()->fromQuery();
        ?>
        <div class="advanced-search-content">
            <?php
            // Fetch Cote property ID dynamically
            $propDataCote = $this->api()->searchOne('properties', ['term' => 'dcterms:bibliographicCitation'])->getContent();
            $propertyIdCote = $propDataCote ? $propDataCote->id() : 'dcterms:bibliographicCitation';
            
            // Retain submitted value for Cote
            $submittedTextCote = '';
            if (isset($query['property'])) {
                foreach ($query['property'] as $pq) {
                    if (isset($pq['property']) && ($pq['property'] == $propertyIdCote || $pq['property'] == 'dcterms:bibliographicCitation')) {
                        $submittedTextCote = $pq['text'] ?? '';
                        break;
                    }
                }
            }
            ?>
            <div id="cote-query" class="field">
                <div class="field-meta">
                    <label>Cote</label>
                </div>
                <div class="inputs">
                    <input type="hidden" name="property[99][joiner]" value="and">
                    <input type="hidden" name="property[99][property]" value="<?php echo $this->escapeHtml($propertyIdCote); ?>">
                    <input type="hidden" name="property[99][type]" value="eq">
                    <input type="text" name="property[99][text]" value="<?php echo $this->escapeHtml($submittedTextCote); ?>" placeholder="Cote">
                </div>
            </div>
            
            <div id="property-queries" class="field custom-filters">
                <div class="field-meta">
                    <span id="by-value-label" class="label">Filtres</span>
                    <div class="field-description">Recherche par champs spécifiques</div>
                </div>
                <div class="inputs custom-filters-grid">
                    <?php
                    // Hack to elegantly fetch distinct values per site without heavy item queries
                    $pathToCheck = __DIR__;
                    $baseDir = null;
                    // On remonte jusqu'à trouver le dossier 'config' à la racine d'Omeka
                    for ($i = 0; $i < 10; $i++) {
                        if (file_exists($pathToCheck . '/config/database.ini')) {
                            $baseDir = $pathToCheck;
                            break;
                        }
                        $pathToCheck = dirname($pathToCheck);
                    }
                    
                    $dbConfig = $baseDir ? parse_ini_file($baseDir . '/config/database.ini') : [];
                    $host = $dbConfig['host'] ?? '127.0.0.1';
                    $dbname = $dbConfig['dbname'] ?? 'omekas';
                    $user = $dbConfig['user'] ?? 'root';
                    $password = $dbConfig['password'] ?? '';
                    $port = isset($dbConfig['port']) && $dbConfig['port'] ? ';port=' . $dbConfig['port'] : '';
                    
                    try {
                        $pdo = new \PDO("mysql:host={$host}{$port};dbname={$dbname}", $user, $password);
                        $pdo->setAttribute(\PDO::ATTR_ERRMODE, \PDO::ERRMODE_EXCEPTION);
                    } catch (\Exception $e) {
                        $pdo = null;
                        // Log the error silently for debugging if enabled
                        if (defined('APPLICATION_ENV') && APPLICATION_ENV === 'development') {
                            error_log("Search custom filters PDO error: " . $e->getMessage());
                        }
                    }

                    $customFilters = [
                        ['label' => 'Année', 'term' => 'index:year'],
                        ['label' => 'Lieu', 'term' => 'index:geogname'],
                        ['label' => 'Organisme', 'term' => 'index:corpname'],
                        ['label' => 'Personne', 'term' => 'index:persname'],
                        ['label' => 'Sujet', 'term' => 'index:subject'],
                        ['label' => 'Typologie documentaire', 'term' => 'index:recordType'],
                        ['label' => 'Lieu de rédaction', 'term' => 'index:placeName'],
                        ['label' => 'correspondent', 'term' => 'index:correspondent'],
                    ];
                    
                    $siteId = $this->layout()->site->id();
                    $index = 0;
                    
                    foreach ($customFilters as $filter):
                        // Fetch proper property ID dynamically
                        $propData = $this->api()->searchOne('properties', ['term' => $filter['term']])->getContent();
                        $propertyId = $propData ? $propData->id() : $filter['term'];
                        
                        // Retain submitted values
                        $submittedText = '';
                        if (isset($query['property'])) {
                            foreach ($query['property'] as $pq) {
                                if (isset($pq['property']) && ($pq['property'] == $propertyId || $pq['property'] == $filter['term'])) {
                                    $submittedText = $pq['text'] ?? '';
                                    break;
                                }
                            }
                        }
                        
                        // Fetch distinct values for datalist
                        $distinctValues = [];
                        if (empty($filter['nolist']) && $pdo && is_numeric($propertyId)) {
                            $stmt = $pdo->prepare("
                                SELECT DISTINCT value
                                FROM value
                                WHERE property_id = :propertyId
                                AND value IS NOT NULL
                                AND value != ''
                                ORDER BY value ASC
                            ");
                            $stmt->execute(['propertyId' => $propertyId]);
                            $distinctValues = $stmt->fetchAll(\PDO::FETCH_COLUMN);
                        }
                        
                        $listId = "list_" . $index;
                    ?>
                    <div class="custom-filter-item">
                        <label><?php echo $this->escapeHtml($filter['label']); ?></label>
                        <input type="hidden" name="property[<?php echo $index; ?>][joiner]" value="and">
                        <input type="hidden" name="property[<?php echo $index; ?>][property]" value="<?php echo $this->escapeHtml($propertyId); ?>">
                        <input type="hidden" name="property[<?php echo $index; ?>][type]" value="eq">
                        <input type="text" name="property[<?php echo $index; ?>][text]" value="<?php echo $this->escapeHtml($submittedText); ?>" placeholder="<?php echo $this->escapeHtml($filter['label']); ?>" <?php if (!empty($distinctValues)) echo 'list="' . $listId . '"'; ?>>
                        <?php if (!empty($distinctValues)): ?>
                        <datalist id="<?php echo $listId; ?>">
                            <?php foreach ($distinctValues as $val): ?>
                                <option value="<?php echo $this->escapeHtml($val); ?>"></option>
                            <?php endforeach; ?>
                        </datalist>
                        <?php endif; ?>
                    </div>
                    <?php 
                    $index++;
                    endforeach; 
                    ?>
                </div>
            </div>
            
            <?php echo $this->partial('common/advanced-search/fulltext', ['query' => $query, 'resourceType' => 'item']); ?>
            <?php echo $this->partial('common/advanced-search/resource-template-restrict', ['query' => $query, 'resourceType' => 'item']); ?>
        </div>
        <script>Omeka.prepareSearchForm($('#advanced-search'));</script>

        <div id="page-actions" class="search-actions">
            <button type="submit" name="submit" class="btn-submit">RECHERCHE</button>
            <button type="button" class="btn-reset" id="reset-search">réinitialiser</button>
        </div>

    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('reset-search').addEventListener('click', function () {
            var form = document.getElementById('advanced-search');
            // Clear all text inputs
            form.querySelectorAll('input[type="text"], input[type="search"]').forEach(function (input) {
                input.value = '';
            });
            // Reset all selects to first option
            form.querySelectorAll('select').forEach(function (select) {
                select.selectedIndex = 0;
            });
            // Remove extra value rows (cloned by Omeka's add-value)
            form.querySelectorAll('.value:not(:first-child)').forEach(function (row) {
                row.remove();
            });
        });
    });
</script>

