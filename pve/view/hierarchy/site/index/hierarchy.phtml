<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$thumbnail = $this->plugin('thumbnail');
$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;
$query = $this->params()->fromQuery();
$hierarchyHeadingLevel = "h2";
$hierarchyItemSetArray = [];

$this->headLink()->appendStylesheet($this->assetUrl('css/hierarchy.css', 'Hierarchy'));
$this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));
$this->htmlElement('body')->appendAttribute('class', 'item resource browse hierarchy-module');
?>
<?php
if ($hierarchyGrouping->getLabel()) {
    echo $this->pageTitle($hierarchyGrouping->getLabel(), 2);
    $hierarchyHeadingLevel = 'h3';
} else if ($hierarchyGrouping->getItemSet()) {
    echo $this->pageTitle($hierarchyGrouping->getItemSet()->displayTitle(null, $valueLang), 2);
    $hierarchyHeadingLevel = 'h3';
}
?>

<div class="hierarchy-row">
    <?php
    $groupings = $this->api()->search('hierarchy_grouping', ['id' => $hierarchyGrouping->id(), 'sort_by' => 'position'])->getContent();

    if ($groupings):
        $siteItemSets = $this->currentSite()->siteItemSets();
        $siteItemSetArray = [];
        foreach ($siteItemSets as $siteItemSet) {
            $siteItemSetArray[] = $siteItemSet->itemSet()->id();
        }

        // -------------------------------------------------------
        // 1. Récupère TOUS les groupings de la hiérarchie en une
        //    seule requête, construit un tableau plat indexé par id
        // -------------------------------------------------------
        $firstGrouping = $groupings[0];
        $currentHierarchy = $firstGrouping->getHierarchy();

        $allGroupings = $this->api()->search('hierarchy_grouping', [
            'hierarchy' => $currentHierarchy,
            'sort_by'   => 'position',
        ])->getContent();

        // Tableau plat : id => [id, parent, label, url, active, hasChildren]
        $nodes = [];
        $siteSlug = $this->currentSite()->slug();
        $activeGroupingId = $hierarchyGrouping->id();
        $hierarchyItemSets = [];

        foreach ($allGroupings as $g) {
            $gId     = $g->id();
            $parent  = $g->getParentGrouping() ?: 0;
            $label   = '';
            $url     = '';
            $private = false;

            if ($g->getItemSet()) {
                try {
                    if ($siteItemSetArray && !in_array($g->getItemSet()->id(), $siteItemSetArray)) {
                        throw new \Exception;
                    }
                    $label = $g->getLabel() ?: $g->getItemSet()->displayTitle(null, $valueLang);
                    $itemSet = $this->api()->read('item_sets', $g->getItemSet()->id())->getContent();
                    $hierarchyItemSets[$gId] = $itemSet;

                    if ($this->siteSetting('hierarchy_link_itemSet')) {
                        $url = $this->url('site/resource-id', ['site-slug' => $siteSlug, 'controller' => 'item-set', 'id' => $itemSet->id()]);
                    } else {
                        $url = $this->url('site/hierarchy', ['site-slug' => $siteSlug, 'grouping-id' => $gId]);
                    }

                    // Pas de lien si pas d'items
                    $itemSetCount = $this->hierarchyHelper()->itemSetCount($g, $allGroupings);
                    if ($itemSetCount === null) {
                        $url = '';
                    }
                } catch (\Exception $e) {
                    $label   = $g->getLabel() ? $g->getLabel() . $this->translate(' (Private)') : $this->translate('(Private)');
                    $url     = '';
                    $private = true;
                }
            } else {
                $label = $g->getLabel() ?: $this->translate('[Untitled]');
                $itemSetCount = $this->hierarchyHelper()->itemSetCount($g, $allGroupings);
                if ($itemSetCount !== null) {
                    $url = $this->url('site/hierarchy', ['site-slug' => $siteSlug, 'grouping-id' => $gId]);
                }
                if ($this->siteSetting('hierarchy_show_count') && $itemSetCount !== null) {
                    $label .= $itemSetCount;
                }
            }

            $nodes[$gId] = [
                'id'      => $gId,
                'parent'  => (int)$parent,
                'label'   => $label,
                'url'     => $url,
                'active'  => ($gId === $activeGroupingId),
                'bold'    => ($gId === $activeGroupingId),
                'private' => $private,
            ];
        }

        // Calcule hasChildren
        foreach ($nodes as &$node) {
            $node['hasChildren'] = false;
        }
        foreach ($nodes as $node) {
            if ($node['parent'] !== 0 && isset($nodes[$node['parent']])) {
                $nodes[$node['parent']]['hasChildren'] = true;
            }
        }
        unset($node);

        // Trouve le chemin actif (pour l'ouvrir au chargement)
        $activePath = [];
        $cur = $activeGroupingId;
        while ($cur && isset($nodes[$cur])) {
            $activePath[] = $cur;
            $cur = $nodes[$cur]['parent'];
        }

        // Racines = nœuds sans parent ou dont le parent n'est pas dans la hiérarchie
        $roots = [];
        foreach ($allGroupings as $g) {
            $p = $g->getParentGrouping() ?: 0;
            if ($p === 0 || !isset($nodes[$p])) {
                $roots[] = $g->id();
            }
        }

        // JSON injecté dans la page (nodes + roots + activePath)
        $jsonData = json_encode([
            'nodes'      => array_values($nodes),
            'roots'      => $roots,
            'activePath' => $activePath,
        ], JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP);
    ?>

        <div class="hierarchy-sidebar-content">
            <div class="hierarchy-metadata">
                <div class="hierarchy-filters">
                    <?php
                    if ($this->siteSetting('hierarchy_show_label') && $currentHierarchy->getLabel()) {
                        echo "<{$hierarchyHeadingLevel}>" . $escape($currentHierarchy->getLabel()) . "</{$hierarchyHeadingLevel}>";
                    }
                    ?>
                    <!-- Racines générées en PHP, reste chargé en JS -->
                    <ul class="hierarchy-list" id="hierarchy-root-list"></ul>
                </div>

                <?php if ($this->siteSetting('hierarchy_display_itemSets') && count($hierarchyItemSets) > 0): ?>
                    <div class="hierarchy-item-sets">
                        <?php
                        $finalItemSet = end($hierarchyItemSets);
                        echo 'Contains resources from: ';
                        foreach ($hierarchyItemSets as $hierarchyItemSet) {
                            echo $hierarchyItemSet->link($hierarchyItemSet->displayTitle());
                            if ($hierarchyItemSet !== $finalItemSet) echo ', ';
                        }
                        ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>

        <!-- Données de l'arbre — injectées côté serveur, consommées par hierarchyPage.js -->
        <script id="hierarchy-data" type="application/json">
            <?= $jsonData ?>
        </script>

    <?php endif; ?>

    <div class="hierarchy-main-content">
        <?php
        if ($this->siteSetting('hierarchy_show_itemSet_metadata') && $itemSet):
            $headingTerm = $this->siteSetting('browse_heading_property_term');
            $bodyTerm    = $this->siteSetting('browse_body_property_term');
            $heading = $headingTerm ? $itemSet->value($headingTerm, ['default' => $translate('[Untitled]'), 'lang' => $valueLang]) : $itemSet->displayTitle(null, $valueLang);
            $body    = $bodyTerm    ? $itemSet->value($bodyTerm,    ['lang' => $valueLang]) : $itemSet->displayDescription(null, $valueLang);
        ?>
            <ul class="resource-list">
                <li class="item-set resource">
                    <div class="hierarchy-itemset-metadata">
                        <?php
                        $linkContent = sprintf(
                            '%s<span class="resource-name">%s</span>',
                            $thumbnail($itemSet, 'medium'),
                            $escape($heading)
                        );
                        echo $itemSet->linkRaw($linkContent, null, ['class' => 'resource-link']);
                        ?>
                        <?php if ($body): ?>
                            <div class="description"><?= $escape($body) ?></div>
                        <?php endif; ?>
                    </div>
                </li>
            </ul>
        <?php endif; ?>

        <?php
        $currentRecord = $hierarchyGrouping->getItemSet();
        if ($currentRecord): ?>
            <div class="hierarchy-metadata-custom" style="margin-bottom: 2em;">
                <?= $currentRecord->displayValues() ?>
            </div>
        <?php endif; ?>

        <div class="hierarchy-items">
            <?= '<h3>' . $escape($translate('Items')) . '</h3>' ?>
            <?= $this->searchFilters() ?>
            <div class="browse-controls">
                <?= $this->pagination() ?>
                <?= $this->hyperlink($translate('Advanced search'), $this->url('site/resource', ['controller' => 'item', 'action' => 'search'], true), ['class' => 'advanced-search']) ?>
                <?= $this->browse()->renderSortSelector('items') ?>
            </div>
            <?php $this->trigger('view.browse.before'); ?>
            <ul class="resource-list">
                <?php
                $headingTerm = $this->siteSetting('browse_heading_property_term');
                $bodyTerm    = $this->siteSetting('browse_body_property_term');
                foreach ($items as $item):
                    $heading = $headingTerm ? $item->value($headingTerm, ['default' => $translate('[Untitled]'), 'lang' => $valueLang]) : $item->displayTitle(null, $valueLang);
                    $body    = $bodyTerm    ? $item->value($bodyTerm,    ['lang' => $valueLang]) : $item->displayDescription(null, $valueLang);
                    $Cote    = $item->value('dcterms:bibliographicCitation');
                    $date    = $item->value('dcterms:date');
                    $user    = $this->identity();
                    $hasVisibleMedia = (count($item->media()) > 0);
                    $privateClass    = (!$hasVisibleMedia && !$user) ? ' is-private' : '';
                ?>
                    <li class="item resource">
                        <?php
                        $linkContent = sprintf(
                            '%s<div class="resource-info"><span class="resource-name">%s</span>%s%s</div>',
                            $thumbnail($item, 'square'),
                            $escape($heading),
                            $Cote ? '<span class="neles-advanced-search__meta-cote">' . $escape($Cote) . '</span>' : '',
                            $date ? '<span class="neles-advanced-search__meta-date">' . $escape($date) . '</span>' : ''
                        );
                        echo $item->linkRaw($linkContent, null, ['class' => 'resource-link' . $privateClass]);
                        ?>
                    </li>
                <?php endforeach; ?>
            </ul>
            <div class="browse-controls">
                <?= $this->pagination() ?>
            </div>
            <?php $this->trigger('view.browse.after'); ?>
        </div>
    </div>
</div>