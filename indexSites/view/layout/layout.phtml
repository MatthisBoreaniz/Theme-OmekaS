<script>
    fetch('/api/sites?per_page=50')
        .then(r => r.json())
        .then(sites => {
            const filtered = sites.filter(s => s['o:slug'] !== 'presentation');
            const assetIds = filtered
                .filter(s => s['o:thumbnail']?.['o:id'])
                .map(s => s['o:thumbnail']['o:id']);

            return Promise.all(
                assetIds.map(id => fetch('/api/assets/' + id).then(r => r.json()))
            ).then(assets => {
                const assetMap = {};
                assets.forEach(a => {
                    assetMap[a['o:id']] = a['o:asset_url'];
                });

                document.getElementById('ea-root').innerHTML = `
                <div class="elliadd-landing">
                    <div class="sites-grid">
                        ${filtered.map(s => {
                            const thumbId = s['o:thumbnail']?.['o:id'];
                            const thumbUrl = thumbId ? assetMap[thumbId] : null;
                            
                            // MODIFICATION ICI : On construit l'URL avec le slug
                            const siteUrl = '/s/' + s['o:slug']; 

                            return `
                                <a href="${siteUrl}" class="site-card">
                                    <div class="site-image">
                                        ${thumbUrl ? `<img src="${thumbUrl}" alt="">` : ''}
                                    </div>
                                    <div class="site-content">
                                        <h2>${s['o:title']}</h2>
                                        ${s['o:summary'] ? `<p>${s['o:summary']}</p>` : ''}
                                    </div>
                                </a>
                            `;
                        }).join('')}
                    </div>
                </div>
            `;
            });
        });
</script>


