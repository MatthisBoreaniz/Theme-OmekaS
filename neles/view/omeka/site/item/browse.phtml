<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$thumbnail = $this->plugin('thumbnail');

$this->htmlElement('body')->appendAttribute('class', 'item resource browse neles-advanced-search');

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;

$query = $this->params()->fromQuery();
$itemSetShow = isset($itemSet);

if ($itemSetShow):
    $this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));
    $query['item_set_id'] = $itemSet->id();
endif;

$searchQuery = isset($query['fulltext_search']) ? trim($query['fulltext_search']) : null;
$isSearchPage = array_key_exists('fulltext_search', $query);
$hasResults = count($items) > 0;
$showZeroState = $isSearchPage && (empty($searchQuery) || !$hasResults);
?>

<div class="neles-advanced-search__container">

<?php if (!$showZeroState): ?>

    <div class="neles-advanced-search__header">
        <?php echo $this->pageTitle($translate('Collections'), 2); ?>
    </div>

    <!-- FILTERS -->
    <div class="neles-advanced-search__filters">
        <?php echo $this->searchFilters(); ?>
    </div>

    <!-- CONTROLS -->
    <div class="neles-advanced-search__controls">
        <div class="neles-advanced-search__pagination">
            <?php echo $this->pagination(); ?>
        </div>

        <div class="neles-advanced-search__actions">
            <?php echo $this->hyperlink(
                $translate('Recherche avancée'),
                $this->url('site/resource', ['controller' => 'item', 'action' => 'search'], ['query' => $query], true),
                ['class' => 'neles-advanced-search__btn']
            ); ?>

            <div class="neles-advanced-search__sort">
                <?php echo $this->browse()->renderSortSelector('items'); ?>
            </div>
        </div>
    </div>

    <!-- LIST -->
    <ul class="neles-advanced-search__list">
    <?php
    $headingTerm = $this->siteSetting('browse_heading_property_term');
    $bodyTerm = $this->siteSetting('browse_body_property_term');

    foreach ($items as $item):

        $Cote = $item->value('dcterms:bibliographicCitation');
        $heading = $headingTerm 
            ? $item->value($headingTerm, ['default' => $translate('[Sans titre]'), 'lang' => $valueLang]) 
            : $item->displayTitle(null, $valueLang);

        $body = $bodyTerm 
            ? $item->value($bodyTerm, ['lang' => $valueLang]) 
            : $item->displayDescription(null, $valueLang);

        $date = $item->value('dcterms:date');
        $place = $item->value('dcterms:spatial');
    ?>
        <li class="neles-advanced-search__item">
            <a href="<?php echo $item->url(); ?>" class="neles-advanced-search__card">

                <div class="neles-advanced-search__thumb">
                    <?php echo $thumbnail($item, 'medium'); ?>
                </div>

                <div class="neles-advanced-search__content">
                    <?php if ($Cote): ?>
                        <span class="neles-advanced-search__meta-cote">
                            <?php echo $escape($Cote); ?>
                        </span>
                    <?php endif; ?>
                    <h3 class="neles-advanced-search__title">
                        <?php echo $escape($heading); ?>
                    </h3>

                    <div class="neles-advanced-search__meta">
                        <?php if ($place): ?>
                            <span class="neles-advanced-search__meta-place">
                                <?php echo $escape($place); ?>
                            </span>
                        <?php endif; ?>

                        <?php if ($date): ?>
                            <span class="neles-advanced-search__meta-date">
                                <?php echo $escape($date); ?>
                            </span>
                        <?php endif; ?>
                    </div>

                    <?php if ($body): ?>
                        <p class="neles-advanced-search__description">
                            <?php echo $escape(mb_strimwidth($body, 0, 220, '...')); ?>
                        </p>
                    <?php endif; ?>

                </div>

            </a>
        </li>
    <?php endforeach; ?>
    </ul>

    <div class="neles-advanced-search__pagination-bottom">
        <?php echo $this->pagination(); ?>
    </div>

<?php else: ?>

<div class="neles-advanced-search__zero">
    <h2>Aucun résultat</h2>
    <p>Essayez une autre recherche ou modifiez les filtres.</p>
</div>

<?php endif; ?>

</div>

