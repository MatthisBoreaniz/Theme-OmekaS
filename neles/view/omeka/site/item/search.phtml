// ── PDO connection ──────────────────────────────────────────────────────────
$pathToCheck = __DIR__;
$baseDir = null;
for ($i = 0; $i < 10; $i++) {
    if (file_exists($pathToCheck . '/config/database.ini')) {
        $baseDir = $pathToCheck;
        break;
    }
    $pathToCheck = dirname($pathToCheck);
}
$dbConfig = $baseDir ? parse_ini_file($baseDir . '/config/database.ini') : [];
$host = $dbConfig['host'] ?? '127.0.0.1';
$dbname = $dbConfig['dbname'] ?? 'omekas';
$user = $dbConfig['user'] ?? 'root';
$password = $dbConfig['password'] ?? '';
$port = isset($dbConfig['port']) && $dbConfig['port'] ? ';port=' . $dbConfig['port'] : '';
try {
    $pdo = new \PDO("mysql:host={$host}{$port};dbname={$dbname}", $user, $password);
    $pdo->setAttribute(\PDO::ATTR_ERRMODE, \PDO::ERRMODE_EXCEPTION);
} catch (\Exception $e) {
    $pdo = null;
}

// ── Helper: get property ID ─────────────────────────────────────────────────
$propIdCache = [];
$getPropId = function (string $term) use (&$propIdCache) {
    if (!isset($propIdCache[$term])) {
        $propData = $this->api()->searchOne('properties', ['term' => $term])->getContent();
        $propIdCache[$term] = $propData ? $propData->id() : $term;
    }
    return $propIdCache[$term];
};

// ── Helper: get submitted value for a property ──────────────────────────────
$getSubmittedValue = function ($propId) use ($query) {
    if (!isset($query['property']))
        return '';
    foreach ($query['property'] as $pq) {
        if (isset($pq['property']) && $pq['property'] == $propId) {
            return $pq['text'] ?? '';
        }
    }
    return '';
};

// ── Helper: get distinct values for datalist (FILTRÉ PAR SITE) ──────────────
$getDistinctValues = function ($propId) use ($pdo, $siteId) {
    if (!$pdo || !is_numeric($propId))
        return [];

    if ($siteId) {
        try {
            // Dans Omeka S, la table liant les items aux sites s'appelle item_site.
            // On vérifie quand même si "site_item" existe au cas où (rétrocompatibilité/modules).
            $linkTable = 'item_site';
            $check = $pdo->query("SHOW TABLES LIKE 'site_item'");
            if ($check && $check->rowCount() > 0) {
                $linkTable = 'site_item';
            }

            $stmt = $pdo->prepare("
                SELECT DISTINCT v.value 
                FROM value v
                INNER JOIN {$linkTable} si ON v.resource_id = si.item_id
                WHERE v.property_id = :pid 
                  AND si.site_id = :site_id
                  AND v.value IS NOT NULL AND v.value != ''
                ORDER BY v.value ASC LIMIT 500
            ");
            $stmt->execute(['pid' => $propId, 'site_id' => $siteId]);
            return $stmt->fetchAll(\PDO::FETCH_COLUMN);
        } catch (\Exception $e) {
            // Si la table n'existe pas ou qu'il y a une erreur SQL, on laisse passer et on utilise le fallback global ci-dessous
        }
    }

    // Requête globale (fallback au cas où appelé hors d'un site ou si la jointure échoue)
    try {
        $stmt = $pdo->prepare("
            SELECT DISTINCT value FROM value
            WHERE property_id = :pid AND value IS NOT NULL AND value != ''
            ORDER BY value ASC LIMIT 500
        ");
        $stmt->execute(['pid' => $propId]);
        return $stmt->fetchAll(\PDO::FETCH_COLUMN);
    } catch (\Exception $e) {
        return [];
    }
};

// ── Helper: render a single filter input ────────────────────────────────────
$idx = 0; // global index for property[] names
